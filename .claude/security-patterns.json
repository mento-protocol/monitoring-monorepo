{
  "patterns": [
    {
      "rule_name": "auth_secret_literal",
      "regex": "(?i)[\"'`]?AUTH_SECRET[\"'`]?\\s*[=:]\\s*[\"'`]?[A-Za-z0-9+/=_-]{16,}[\"'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "AUTH_SECRET assigned a literal value. Load from env at runtime; never inline. Generate with `openssl rand -hex 32`."
    },
    {
      "rule_name": "upstash_token_literal",
      "regex": "(?i)[\"'`]?(KV_REST_API_(READ_ONLY_)?|UPSTASH_REDIS_REST_)TOKEN[\"'`]?\\s*[=:]\\s*[\"'`]?[A-Za-z0-9_-]{20,}[\"'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "Upstash REST token inlined. Move to `.env.local` or Vercel env vars. Rotate immediately if this leaks."
    },
    {
      "rule_name": "envio_hasura_token_literal",
      "regex": "(?i)[\"'`]?ENVIO_HASURA_(ADMIN_)?TOKEN[\"'`]?\\s*[=:]\\s*[\"'`]?[A-Za-z0-9_-]{20,}[\"'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "Envio Hasura token inlined. Read from env at runtime; never commit."
    },
    {
      "rule_name": "sentry_auth_token_literal",
      "regex": "(?i)[\"'`]?SENTRY_AUTH_TOKEN[\"'`]?\\s*[=:]\\s*[\"'`]?[A-Za-z0-9_-]{20,}[\"'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "Sentry auth token inlined. Read from env; never commit. Rotate via Sentry org auth tokens page if this leaks."
    },
    {
      "rule_name": "dune_api_key_literal",
      "regex": "(?i)[\"'`]?DUNE_API_KEY[\"'`]?\\s*[=:]\\s*[\"'`]?[A-Za-z0-9_-]{20,}[\"'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "Dune API key inlined. Read from env; never commit. Rotate via dune.com \u2192 Settings \u2192 API."
    },
    {
      "rule_name": "arkham_api_key_literal",
      "regex": "(?i)[\"'`]?ARKHAM_API_KEY[\"'`]?\\s*[=:]\\s*[\"'`]?[A-Za-z0-9_-]{20,}[\"'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "Arkham API key inlined. Read from env; never commit. Rotate via intel.arkm.com \u2192 Settings if this leaks."
    },
    {
      "rule_name": "slack_bot_token_env_literal",
      "regex": "(?i)[\"'`]?([A-Z][A-Z0-9_]*_)?SLACK_BOT_TOKEN[\"'`]?\\s*[=:]\\s*[\"\\'`]?[A-Za-z0-9_-]{20,}[\"\\'`]?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "Slack bot token inlined in an env assignment. Read from env; never commit. Rotate via Slack app settings if this leaks."
    },
    {
      "rule_name": "slack_bot_token",
      "reminder": "Slack token literal detected. Move to env. Rotate via Slack app settings if this commits.",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/test/**",
        "test/**",
        "**/tests/**",
        "tests/**",
        "**/__tests__/**",
        "__tests__/**",
        "**/*.test.ts",
        "*.test.ts",
        "**/*.spec.ts",
        "*.spec.ts",
        "**/fixtures/**",
        "fixtures/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "regex": "(xoxb-|xoxe\\.xoxp-|xoxa-2-|xoxp-)[A-Za-z0-9_-]{8,}-[A-Za-z0-9_-]{8,}"
    },
    {
      "rule_name": "aws_access_key",
      "regex": "(AKIA|ASIA)[A-Z2-7]{16}",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        ".env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/test/**",
        "test/**",
        "**/tests/**",
        "tests/**",
        "**/__tests__/**",
        "__tests__/**",
        "**/*.test.ts",
        "*.test.ts",
        "**/*.spec.ts",
        "*.spec.ts",
        "**/fixtures/**",
        "fixtures/**",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "AWS access-key literal detected. Use workload identity / instance profiles, not literal credentials."
    },
    {
      "rule_name": "bearer_live_token_literal",
      "regex": "[\"\\']?(sk_live_|rk_live_)[A-Za-z0-9]{20,}[\"\\']?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/test/**",
        "test/**",
        "**/tests/**",
        "tests/**",
        "**/__tests__/**",
        "__tests__/**",
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/fixtures/**",
        "fixtures/**",
        "**/*.md",
        "**/*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**",
        "**/*.mdx",
        "*.mdx",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "*.md",
        "*.mdc",
        "*.test.ts",
        "*.test.tsx",
        "*.spec.ts",
        "*.spec.tsx"
      ],
      "reminder": "Bearer live-token literal detected (sk_live_/rk_live_). Load from secrets manager; never inline. Rotate immediately if this leaks."
    },
    {
      "rule_name": "private_key_literal",
      "regex": "[`\"\\']0x[a-fA-F0-9]{64}[`\"\\']",
      "exclude_paths": [
        "**/test/**",
        "test/**",
        "**/tests/**",
        "tests/**",
        "**/__tests__/**",
        "__tests__/**",
        "**/*.test.ts",
        "*.test.ts",
        "**/*.spec.ts",
        "*.spec.ts",
        "**/fixtures/**",
        "fixtures/**",
        "**/mock*/**",
        "mock*/**",
        "**/.claude/**",
        ".claude/**",
        "**/aegis/config.yaml",
        "aegis/config.yaml",
        "**/aegis/config.yml",
        "aegis/config.yml",
        "**/alerts/infra/**/*.yaml",
        "alerts/infra/**/*.yaml",
        "**/alerts/infra/**/*.yml",
        "alerts/infra/**/*.yml",
        "**/alerts/infra/**/test-payloads/**",
        "alerts/infra/**/test-payloads/**",
        "**/alerts/infra/onchain-event-listeners/**",
        "alerts/infra/onchain-event-listeners/**",
        "**/*.test.tsx",
        "*.test.tsx",
        "**/*.spec.tsx",
        "*.spec.tsx",
        "**/alerts/infra/onchain-event-handler/scripts/test-payload.json",
        "alerts/infra/onchain-event-handler/scripts/test-payload.json",
        "**/alerts/infra/onchain-event-handler/scripts/**",
        "alerts/infra/onchain-event-handler/scripts/**",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.env*.example",
        ".env*.example",
        "**/*.example",
        "*.example",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**"
      ],
      "reminder": "64-hex literal looks like a private key or signature. If it's a contract address it should be 40 hex (0x[40 chars]). Transaction and block hashes are also 64 hex chars \u2014 if that's the case, move the constant to config or a fixture. Confirm and move secrets to env."
    },
    {
      "rule_name": "private_key_env_literal",
      "regex": "(?i)[\"\\']?(PRIVATE_KEY|DEPLOYER_PRIVATE_KEY|SIGNER_PRIVATE_KEY|WALLET_PRIVATE_KEY)[\"\\']?\\s*[=:]\\s*[\"\\']?0x[a-fA-F0-9]{64}[\"\\']?",
      "exclude_paths": [
        "**/*.example",
        "*.example",
        "**/.env*.example",
        "**/.env",
        ".env",
        "**/.env.*",
        ".env.*",
        "**/.claude/**",
        ".claude/**",
        "**/test/**",
        "test/**",
        "**/tests/**",
        "tests/**",
        "**/__tests__/**",
        "__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/fixtures/**",
        "fixtures/**",
        "**/*.md",
        "*.md",
        "**/*.mdx",
        "*.mdx",
        "**/*.mdc",
        "*.mdc",
        "**/README.md",
        "README.md",
        "**/README.*",
        "README.*",
        "**/docs/**",
        "docs/**",
        "**/.cursor/**",
        ".cursor/**",
        "*.test.ts",
        "*.test.tsx",
        "*.spec.ts",
        "*.spec.tsx"
      ],
      "reminder": "PRIVATE_KEY-shape env literal detected (named var assigned a 64-hex value). Load from secrets manager / KMS at runtime; never inline or commit."
    },
    {
      "rule_name": "hasura_aggregate_query",
      "regex": "_aggregate\\s*[({]",
      "paths": [
        "**/scripts/**/*.gql",
        "scripts/**/*.gql",
        "**/scripts/**/*.graphql",
        "scripts/**/*.graphql",
        "**/scripts/**/*.js",
        "scripts/**/*.js",
        "**/scripts/**/*.mjs",
        "scripts/**/*.mjs",
        "**/scripts/**/*.ts",
        "scripts/**/*.ts",
        "**/scripts/**/*.tsx",
        "scripts/**/*.tsx",
        "**/ui-dashboard/**/*.gql",
        "ui-dashboard/**/*.gql",
        "**/ui-dashboard/**/*.graphql",
        "ui-dashboard/**/*.graphql",
        "**/ui-dashboard/**/*.js",
        "ui-dashboard/**/*.js",
        "**/ui-dashboard/**/*.mjs",
        "ui-dashboard/**/*.mjs",
        "**/ui-dashboard/**/*.ts",
        "ui-dashboard/**/*.ts",
        "**/ui-dashboard/**/*.tsx",
        "ui-dashboard/**/*.tsx",
        "**/metrics-bridge/**/*.ts",
        "metrics-bridge/**/*.ts",
        "**/metrics-bridge/**/*.graphql",
        "metrics-bridge/**/*.graphql",
        "**/metrics-bridge/**/*.gql",
        "metrics-bridge/**/*.gql"
      ],
      "reminder": "Hasura `_aggregate` queries are unbounded on prod and have caused 429 storms. Use a pre-rolled snapshot entity or paginate + count client-side."
    },
    {
      "rule_name": "bare_gcloud_in_app",
      "regex": "(spawn|exec|execSync|execFile|execFileSync|spawnSync)\\(\\s*[`\"\\']gcloud",
      "paths": [
        "**/indexer-envio/**/*.ts",
        "indexer-envio/**/*.ts",
        "**/ui-dashboard/**/*.ts",
        "ui-dashboard/**/*.ts",
        "**/ui-dashboard/**/*.tsx",
        "ui-dashboard/**/*.tsx",
        "**/aegis/**/*.ts",
        "aegis/**/*.ts",
        "**/metrics-bridge/**/*.ts",
        "metrics-bridge/**/*.ts"
      ],
      "reminder": "App code is shelling out to gcloud. Use the GCP client libraries with workload identity instead \u2014 CLI calls won't work in Vercel/Cloud Run."
    },
    {
      "rule_name": "indexer_handler_throw",
      "regex": "\\bthrow\\b",
      "paths": [
        "**/indexer-envio/src/handlers/*.ts",
        "indexer-envio/src/handlers/*.ts",
        "**/indexer-envio/src/handlers/**/*.ts",
        "indexer-envio/src/handlers/**/*.ts"
      ],
      "exclude_paths": [
        "**/indexer-envio/src/handlers/**/__tests__/**",
        "indexer-envio/src/handlers/**/__tests__/**",
        "**/indexer-envio/src/handlers/**/config.ts",
        "indexer-envio/src/handlers/**/config.ts",
        "**/indexer-envio/test/**",
        "indexer-envio/test/**",
        "**/indexer-envio/src/handlers/v2Stables/transfer.ts",
        "indexer-envio/src/handlers/v2Stables/transfer.ts"
      ],
      "reminder": "Throwing from an Envio handler (any form \u2014 Error, TypeError, custom, re-throw) halts the indexer (Sev-1). Use `context.log.error('<area>.<event>', {...})` and return early so the next event is processed."
    },
    {
      "rule_name": "number_coerce_onchain_value",
      "regex": "Number\\([^)]*\\b_?(amount|balance|supply|totalSupply|reserve|debt|deposit|withdrawal|netflow|limit|timestamp|blockTimestamp)",
      "paths": [
        "**/indexer-envio/src/*.ts",
        "indexer-envio/src/*.ts",
        "**/indexer-envio/src/**/*.ts",
        "indexer-envio/src/**/*.ts"
      ],
      "reminder": "Coercing an on-chain bigint to Number loses precision above 2^53. Keep it as bigint, or format for display only at the very edge. Matches suffixed forms too (amount0In, reserve1, netflowGlobal, limit0, blockTimestamp, etc.)."
    },
    {
      "rule_name": "workflow_action_unpinned",
      "regex": "(?:[\"\\']?uses[\"\\']?:\\s*[\"\\']?(?!actions/|github/)[A-Za-z0-9._/-]+@(?![a-fA-F0-9]{40}\\b)\\S+)|(?:[\"\\']?uses[\"\\']?:\\s*[\"\\']?docker://(?!\\S+@sha256:)\\S+)",
      "paths": ["**/.github/workflows/**", ".github/workflows/**"],
      "reminder": "Third-party Actions must be pinned: GitHub Actions to a full 40-char commit SHA (`owner/repo@<sha> # tag`), Docker images to an immutable digest (`docker://image@sha256:<digest>`). Catches `@v1`, `@v1.2.3`, `@main`, `@latest`, `@stable`, subdirectory actions, and tag-only Docker images. First-party `actions/*` and `github/*` are intentionally exempt."
    },
    {
      "rule_name": "workflow_pr_write_permission",
      "regex": "[\"\\']?(pull-requests|contents|permissions)[\"\\']?:\\s*[\"\\']?(write|write-all)[\"\\']?",
      "paths": ["**/.github/workflows/**", ".github/workflows/**"],
      "reminder": "Workflow grants write permission. If this workflow has a `pull_request` trigger, confirm it gates on `github.event.pull_request.head.repo.full_name == github.repository` so forks don't get write tokens. (workflow_dispatch-only or push-only workflows can ignore this.)",
      "exclude_paths": [
        "**/.github/workflows/update-snapshots.yml",
        ".github/workflows/update-snapshots.yml",
        "**/.github/workflows/aegis-app-engine.yml",
        ".github/workflows/aegis-app-engine.yml",
        "**/.github/workflows/release-*.yml",
        ".github/workflows/release-*.yml"
      ]
    },
    {
      "rule_name": "webhook_no_hmac_check",
      "regex": "(req\\.body|request\\.body|req\\.rawBody|request\\.rawBody|await\\s+req\\.json|await\\s+request\\.json|validatePayload\\s*\\()",
      "paths": [
        "**/alerts/infra/onchain-event-handler/src/*.ts",
        "alerts/infra/onchain-event-handler/src/*.ts",
        "**/alerts/infra/onchain-event-handler/src/**/*.ts",
        "alerts/infra/onchain-event-handler/src/**/*.ts"
      ],
      "exclude_paths": [
        "**/test/**",
        "test/**",
        "**/tests/**",
        "tests/**",
        "**/__tests__/**",
        "__tests__/**",
        "**/*.test.ts",
        "*.test.ts",
        "**/*.spec.ts",
        "*.spec.ts",
        "**/verify-quicknode-signature.ts",
        "verify-quicknode-signature.ts",
        "**/validate-quicknode-webhook.ts",
        "validate-quicknode-webhook.ts",
        "**/validate-payload.ts",
        "validate-payload.ts",
        "**/check-payload-size.ts",
        "check-payload-size.ts"
      ],
      "reminder": "QuickNode webhook handler reads/parses request body \u2014 verify the signature with `verify-quicknode-signature.ts` BEFORE parsing the body or calling `validatePayload(req)`, not after. Reject unauthenticated requests early. (check-payload-size.ts is the intentional pre-sig DoS-rejection gate and is excluded from this rule.)"
    }
  ]
}
