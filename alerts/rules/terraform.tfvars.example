# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit it.

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot User OAuth Token from the "Grafana Alerts" Slack app.
# Create / manage at: https://api.slack.com/apps
# Required scopes: chat:write, chat:write.public (chat:write.customize optional).
# The bot must be invited to every channel it posts to: /invite @Grafana Alerts.
slack_bot_token = "xoxb-REPLACE_ME"

# ── Grafana ───────────────────────────────────────────────────────────────────
# Service account token for the Grafana Cloud stack. Create at:
#   Grafana Cloud → Administration → Service accounts → Add token.
# Needs at least Admin role to create folders + alert rules.
grafana_service_account_token = "glsa_REPLACE_ME"

# Override the stack URL or channels only if they change:
# grafana_url            = "https://clabsmento.grafana.net"
# slack_channel_critical = "#alerts-critical"
# slack_channel_oracles  = "#alerts-oracles"
# slack_channel_pools    = "#alerts-pools"
# slack_channel_infra    = "#alerts-infra"
# slack_channel_reserve  = "#alerts-reserve"
# slack_channel_testnet  = "#alerts-testnet"
# slack_channel_warnings = "#alerts-warning" # [DEPRECATED] retained for dual-route compatibility

# ── Legacy protocol routing ───────────────────────────────────────────────────
# These values moved here from aegis/terraform. They still feed the global
# Grafana notification policy for protocol + Aegis service-health alerts.
discord_alerts_webhook_url_staging               = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_prod                  = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_reserve               = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_trading_modes_staging = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_trading_modes_prod    = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_trading_limits        = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_aegis                 = "https://discord.com/api/webhooks/REPLACE_ME"
discord_alerts_webhook_url_catch_all             = "https://discord.com/api/webhooks/REPLACE_ME"
splunk_on_call_alerts_webhook_url                = "https://alert.victorops.com/integrations/generic/REPLACE_ME/alert/REPLACE_ME"
