{
  "name": "@mento-protocol/alerts-oncall-announcer",
  "version": "1.0.0",
  "private": true,
  "description": "Announces Splunk On-Call rotations to Slack and reconciles the support-engineer usergroup",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "nodemon --ext ts --ignore dist --exec \"pnpm run start\"",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "knip": "knip --config knip.json --no-progress",
    "knip:report": "knip --config knip.json --no-exit-code --no-progress",
    "lint": "eslint src/",
    "prestart": "pnpm run build",
    "start": "NODE_ENV=development functions-framework --target=handleOncallRotation",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "4.0.0",
    "@google-cloud/logging": "^11.2.1",
    "env-schema": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.1",
    "knip": "^5.70.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "body-parser@<1.20.5": "1.20.5",
    "express": "4.22.2",
    "js-yaml": "^4.1.1",
    "qs": ">=6.14.2",
    "uuid": "11.1.1"
  }
}
