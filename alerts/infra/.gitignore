# Terraform state — managed remotely in GCS (mento-terraform-tfstate-6ed6/alerts).
terraform.tfstate
terraform.tfstate.backup

# Variable values — contain secrets (Discord/Sentry/QuickNode tokens).
terraform.tfvars
*.auto.tfvars
*.tfvars.json

# Provider cache — regenerated by `terraform init`.
.terraform/
.terraform-agent-gate/

# .terraform.lock.hcl is intentionally committed.

# Cloud Function source archive — generated by data.archive_file at apply time.
*.zip

# Project-vars cache — scripts/get-project-vars.sh writes terraform-state-derived
# vars (project_id, region, etc.) here to avoid re-querying state.
onchain-event-handler/.project_vars_cache

# Terraform-generated copy of safe-abi.json — null_resource.copy_safe_abi writes
# this into the handler module on every plan so the Cloud Fn source archive
# picks up the ABI. Source of truth is alerts/infra/safe-abi.json at the TF root.
onchain-event-handler/safe-abi.json

# Local dev .env — generated by `npm run generate:env` (terraform apply target).
onchain-event-handler/.env
onchain-event-handler/.env.local
