{
  "name": "@mento-protocol/alerts-onchain-event-handler",
  "version": "1.0.0",
  "private": true,
  "description": "Routes QuickNode webhook events to Slack for Safe multisig monitoring",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "build:event-hashes": "node scripts/build-event-hashes.mjs",
    "deploy": "./scripts/deploy.sh",
    "dev": "nodemon --ext ts --ignore dist --exec \"pnpm run start\"",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "generate:env": "terraform -chdir=.. apply -replace=module.onchain_event_handler.terraform_data.env_file -target=module.onchain_event_handler.terraform_data.env_file",
    "health": "./scripts/test-healthcheck.sh",
    "knip": "knip --config knip.json --no-progress",
    "knip:report": "knip --config knip.json --no-exit-code --no-progress",
    "lint": "eslint src/",
    "logs": "./scripts/get-logs.sh",
    "logs:tail": "./scripts/tail-logs.sh",
    "prestart": "pnpm run build",
    "start": "NODE_ENV=development functions-framework --target=processQuicknodeWebhook",
    "tail": "pnpm run logs:tail",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:local": "./scripts/test-local.sh",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "4.0.0",
    "@google-cloud/logging": "^11.2.1",
    "axios": "^1.13.2",
    "env-schema": "^7.0.0",
    "keccak": "^3.0.4",
    "viem": "2.50.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/keccak": "^3.0.5",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.10",
    "eslint": "^9.39.1",
    "knip": "^5.70.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.10"
  },
  "overrides": {
    "body-parser@<1.20.5": "1.20.5",
    "express": "4.22.2",
    "js-yaml": "^4.1.1",
    "qs": ">=6.14.2",
    "uuid": "11.1.1"
  }
}
