# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).
#
# For more information, run:
#   $ gcloud topic gcloudignore
#
.gcloudignore
# If you would like to upload your .git directory, .gitignore file or files
# from your .gitignore file, remove the corresponding line
# below:
.git
.gitignore

node_modules

# Dev-only files that must NEVER reach the Cloud Build source bundle.
# Terraform's archive_file already strips these (see archive_file.function_source
# in main.tf) but `gcloud functions deploy --source=` from scripts/deploy.sh
# uses .gcloudignore instead — keep these two in sync. .env files are the
# most dangerous: scripts/generate:env writes QUICKNODE_SIGNING_SECRET +
# both Discord webhook URLs into them locally.
.env
.env.*
.project_vars_cache

# Test files — bundled-into-prod-zip noise + leak the test fixture.
**/*.test.ts
**/*.test.js

# Operator scripts, formatter configs, vitest config. None needed at runtime;
# shipping `scripts/test-payload.json` leaks the canonical webhook payload
# schema and the .sh files reveal internal gcloud + Terraform invocations.
scripts
vitest.config.ts
eslint.config.mjs
knip.json
.prettierrc.json
.prettierignore

# Terraform artifacts (only present if someone ran `terraform plan` inside
# the module dir by mistake — defensive).
.terraform
**/*.tfstate
**/*.tfstate.backup
**/*.tfvars
**/*.tfvars.json
function-source.zip
