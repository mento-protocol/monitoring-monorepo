{
  "name": "@mento-protocol/monitoring-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "postinstall": "pnpm --filter @mento-protocol/monitoring-config build",
    "dashboard:build": "pnpm --filter @mento-protocol/ui-dashboard build",
    "dashboard:size-limit": "pnpm --filter @mento-protocol/ui-dashboard size-limit",
    "dashboard:dev": "pnpm --filter @mento-protocol/ui-dashboard dev",
    "dashboard:mutation": "pnpm --filter @mento-protocol/ui-dashboard test:mutation",
    "dashboard:react-doctor": "pnpm --filter @mento-protocol/ui-dashboard react-doctor",
    "dashboard:react-doctor:diff": "pnpm --filter @mento-protocol/ui-dashboard react-doctor --diff origin/main --fail-on warning --offline",
    "integrations:probe": "pnpm --filter @mento-protocol/integration-probes probe",
    "integrations:probe:test": "pnpm --filter @mento-protocol/integration-probes test",
    "deploy:dashboard": "./scripts/deploy-dashboard.sh",
    "agent:quality-gate": "./scripts/agent-quality-gate.sh",
    "agent:quality-gate:test": "bash scripts/agent-quality-gate.test.sh",
    "agent:prewarm": "node scripts/agent-prewarm.mjs",
    "agent:prewarm:test": "node scripts/agent-prewarm.test.mjs",
    "agent:context-check": "node scripts/check-agent-context.mjs",
    "agent:autoreview": "./scripts/agent-autoreview.sh",
    "pr:feedback-state": "node scripts/pr-feedback-state.mjs",
    "pr:feedback-state:test": "node scripts/pr-feedback-state.test.mjs",
    "pr:ready-state": "node scripts/pr-ready-state.mjs",
    "pr:ready-state:test": "node scripts/pr-ready-state.test.mjs",
    "tf": "node scripts/tf-stacks.mjs",
    "tf:test": "node scripts/tf-stacks.test.mjs",
    "aegis:build": "pnpm --filter @mento-protocol/aegis build",
    "aegis:dev": "pnpm --filter @mento-protocol/aegis dev",
    "aegis:typecheck": "pnpm --filter @mento-protocol/aegis typecheck",
    "aegis:test": "pnpm --filter @mento-protocol/aegis test",
    "aegis:lint": "pnpm --filter @mento-protocol/aegis lint",
    "aegis:deploy": "pnpm --filter @mento-protocol/aegis run deploy",
    "aegis:logs": "pnpm --filter @mento-protocol/aegis logs",
    "aegis:tf:init": "terraform -chdir=aegis/terraform init",
    "aegis:tf:plan": "pnpm tf plan aegis",
    "aegis:agent:seed-secrets": "pnpm --filter @mento-protocol/aegis agent:seed-secrets",
    "aegis:agent:deploy": "pnpm --filter @mento-protocol/aegis agent:deploy",
    "deploy:indexer": "./scripts/deploy-indexer.sh",
    "deploy:indexer:status": "./scripts/deploy-indexer-status.sh",
    "deploy:indexer:promote": "./scripts/deploy-indexer-promote.sh",
    "deploy:indexer:logs": "./scripts/deploy-indexer-logs.sh",
    "deploy:indexer:metrics": "./scripts/deploy-indexer-metrics.sh",
    "deploy:indexer:info": "./scripts/deploy-indexer-info.sh",
    "indexer:codegen": "pnpm --filter @mento-protocol/indexer-envio codegen --config config.multichain.mainnet.yaml",
    "indexer:dev": "pnpm --filter @mento-protocol/indexer-envio dev --config config.multichain.mainnet.yaml",
    "code-health:knip": "pnpm -r --workspace-concurrency=1 knip",
    "code-health:knip:report": "pnpm -r --workspace-concurrency=1 knip:report",
    "code-health:deps": "depcruise --config .dependency-cruiser.cjs shared-config ui-dashboard indexer-envio metrics-bridge integration-probes aegis",
    "code-health:deps:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot shared-config ui-dashboard indexer-envio metrics-bridge integration-probes aegis | dot -T svg > reports/dep-graph.svg",
    "code-health:history": "node scripts/code-health-history.mjs",
    "code-health:duplication": "jscpd --config .jscpd.json",
    "code-health": "pnpm code-health:knip && pnpm code-health:deps",
    "lint:scripts": "eslint scripts/ eslint.config.mjs .dependency-cruiser.cjs",
    "indexer:mutation": "pnpm --filter @mento-protocol/indexer-envio test:mutation",
    "indexer:testnet:codegen": "pnpm --filter @mento-protocol/indexer-envio codegen --config config.multichain.testnet.yaml",
    "indexer:testnet:dev": "pnpm --filter @mento-protocol/indexer-envio dev --config config.multichain.testnet.yaml",
    "bridge:dev": "pnpm --filter @mento-protocol/metrics-bridge dev",
    "bridge:build": "pnpm --filter @mento-protocol/metrics-bridge build",
    "bridge:test": "pnpm --filter @mento-protocol/metrics-bridge test",
    "bridge:mutation": "pnpm --filter @mento-protocol/metrics-bridge test:mutation",
    "bridge:deploy": "./scripts/deploy-bridge.sh",
    "infra:apply": "pnpm tf apply platform",
    "infra:init": "terraform -chdir=terraform init",
    "infra:plan": "pnpm tf plan platform",
    "alerts:rules:init": "terraform -chdir=alerts/rules init",
    "alerts:rules:plan": "pnpm tf plan alerts-rules",
    "alerts:infra:init": "terraform -chdir=alerts/infra init",
    "alerts:infra:plan": "pnpm tf plan alerts-delivery",
    "alerts:handler:build": "pnpm --filter @mento-protocol/alerts-onchain-event-handler build",
    "alerts:handler:typecheck": "pnpm --filter @mento-protocol/alerts-onchain-event-handler typecheck",
    "alerts:handler:test": "pnpm --filter @mento-protocol/alerts-onchain-event-handler test",
    "alerts:oncall:build": "pnpm --filter @mento-protocol/alerts-oncall-announcer build",
    "alerts:oncall:typecheck": "pnpm --filter @mento-protocol/alerts-oncall-announcer typecheck",
    "alerts:oncall:test": "pnpm --filter @mento-protocol/alerts-oncall-announcer test",
    "gov-watchdog:build": "pnpm --filter @mento-protocol/governance-watchdog build",
    "gov-watchdog:typecheck": "pnpm --filter @mento-protocol/governance-watchdog typecheck",
    "gov-watchdog:test": "pnpm --filter @mento-protocol/governance-watchdog test:unit",
    "gov-watchdog:lint": "pnpm --filter @mento-protocol/governance-watchdog lint",
    "gov-watchdog:deploy": "./scripts/deploy-gov-watchdog.sh",
    "gov-watchdog:logs": "pnpm --filter @mento-protocol/governance-watchdog logs",
    "gov-watchdog:tf:init": "terraform -chdir=governance-watchdog/infra init",
    "gov-watchdog:tf:plan": "pnpm tf plan governance-watchdog",
    "lockfile:lint": "node scripts/lockfile-lint.mjs",
    "lockfile:lint:test": "node scripts/lockfile-lint.test.mjs",
    "skew:check": "node scripts/version-skew-check.mjs",
    "skew:check:test": "node scripts/version-skew-check.test.mjs",
    "code-health:schema-diff": "git show origin/main:indexer-envio/schema.graphql > /tmp/schema-base-local.graphql && node scripts/schema-diff.mjs /tmp/schema-base-local.graphql indexer-envio/schema.graphql"
  },
  "pnpm": {
    "overrides": {
      "envio>react": "19.2.6",
      "flatted": ">=3.4.2",
      "serialize-javascript": ">=7.0.5",
      "diff@>=6": ">=8.0.3",
      "brace-expansion@>=2.0.0 <3": "^2.0.3",
      "brace-expansion@>=5.0.0 <6": "^5.0.5",
      "postcss": ">=8.5.10",
      "picomatch": ">=4.0.4",
      "vite": ">=8.0.8",
      "@grpc/grpc-js": "1.14.4",
      "esbuild": "0.28.1",
      "body-parser@<1.20.3": "1.20.3",
      "path-to-regexp@<0.1.13": "0.1.13",
      "fast-uri": ">=3.1.1",
      "express@<4.20.0": "4.22.1",
      "qs@<6.14.2": "6.14.2",
      "cookie@<0.7.0": "0.7.2",
      "send@<0.19.0": "0.19.2",
      "serve-static@<1.16.0": "1.16.3",
      "@eslint/eslintrc": ">=3.3.5",
      "@nestjs/core": ">=11.1.18",
      "ajv@^6.0.0": "^6.14.0",
      "ajv@^8.0.0": ">=8.18.0",
      "body-parser@>=2.0.0 <2.2.1": "2.2.1",
      "brace-expansion@^1.0.0": "^1.1.13",
      "cron": "4.3.4",
      "diff@^4.0.0": "^4.0.4",
      "file-type@^21.0.0": "^21.3.2",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.17.23",
      "minimatch@^3.0.0": "^3.1.4",
      "minimatch@^9.0.0": "^9.0.7",
      "minimatch@^10.0.0": "^10.2.3",
      "multer": ">=2.1.1",
      "path-to-regexp@^8.0.0": "^8.4.0",
      "picomatch@^2.0.0": "^2.3.2",
      "qs": ">=6.14.2",
      "tar": ">=7.5.11",
      "@lhci/cli>tmp": "0.2.6",
      "external-editor>tmp": "0.2.6",
      "webpack": ">=5.104.1",
      "ws@>=8.0.0 <8.20.1": "8.20.1",
      "yaml@^2.0.0": "^2.8.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "dependency-cruiser": "17.4.0",
    "envio-cloud": "0.9.2",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "graphql": "16.13.1",
    "js-yaml": "4.1.1",
    "jscpd": "4.0.9",
    "turbo": "^2.9.14"
  }
}
