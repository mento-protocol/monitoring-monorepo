# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit it.

# ── Vercel ────────────────────────────────────────────────────────────────────
# Create at: vercel.com → Account Settings → Tokens
vercel_token = "vcp_..."

# Team ID — default is already set in variables.tf; override only if changed.
# vercel_team_id = "team_4l4TPoxnWEcusT8VeXkHbzF2"

# ── Upstash ───────────────────────────────────────────────────────────────────
# API credentials at: console.upstash.com → Account → API Keys
upstash_email   = "your@email.com"
upstash_api_key = "..."

# Primary region for the Redis database — closest to your Vercel deployment region.
# upstash_region = "eu-west-1"

# ── Hasura / Envio ────────────────────────────────────────────────────────────
# Default in variables.tf points to the current Envio endpoint.
# Override here only if the deployment ID changes.
# hasura_url = "https://indexer.hyperindex.xyz/2f3dd15/v1/graphql"

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Provision the store once (see README), then paste the token here.
# blob_read_write_token = "vercel_blob_rw_..."

# ── Google Cloud (metrics-bridge) ─────────────────────────────────────────────
# Find with: gcloud organizations list
gcp_org_id = "..."

# Find with: gcloud billing accounts list
gcp_billing_account = "..."

# GCP project ID — defaults to "mento-monitoring" in variables.tf.
# gcp_project_id = "mento-monitoring"

# Container image for the metrics-bridge Cloud Run service.
# Built by CI on merge to main, or manually via `pnpm bridge:deploy`.
# Leave empty until first image is built — Cloud Run won't be provisioned.
# metrics_bridge_image = "europe-west1-docker.pkg.dev/mento-monitoring/metrics-bridge/metrics-bridge:abc123"

# Dev team IAM — defaults to group:eng@mentolabs.xyz in variables.tf.
# gcp_dev_members = ["group:eng@mentolabs.xyz"]

# Caller must have roles/iam.serviceAccountTokenCreator on this SA.
# terraform_service_account = "org-terraform@mento-terraform-seed-ffac.iam.gserviceaccount.com"
