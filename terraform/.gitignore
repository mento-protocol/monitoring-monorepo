# Terraform state — managed remotely in GCS (mento-terraform-tfstate-6ed6/monitoring-monorepo).
# Local copies are kept here only as a transient artifact of init; they are not authoritative.
terraform.tfstate
terraform.tfstate.backup

# Variable values — contain secrets.
terraform.tfvars
*.auto.tfvars

# Provider cache — regenerated by `terraform init`.
.terraform/

# .terraform.lock.hcl is intentionally committed.
# It pins provider versions for reproducible runs across machines.
