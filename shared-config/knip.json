{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/*.ts", "__tests__/**/*.test.ts"],
  "project": ["src/**/*.ts", "__tests__/**/*.ts", "*.config.*"],
  "ignoreDependencies": ["@vitest/coverage-v8"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
