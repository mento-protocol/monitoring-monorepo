{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/EventHandlers.ts",
    "src/EventHandlersBridgeOnly.ts",
    "src/EventHandlersReserveYield.ts",
    "src/indexer.ts",
    "vitest.mutation.config.ts",
    "scripts/*.mjs"
  ],
  "project": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.mjs", "*.config.*"],
  "ignoreDependencies": ["@vitest/coverage-v8"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
