{
  "name": "@mento-protocol/indexer-envio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "tsc --clean",
    "build": "tsc --build",
    "watch": "tsc --watch",
    "mocha": "ts-mocha --timeout 10000 test/**/*.ts",
    "codegen": "node ./scripts/run-envio-with-env.mjs codegen",
    "dev": "node ./scripts/run-envio-with-env.mjs dev",
    "start": "node ./scripts/run-envio-with-env.mjs start",
    "stop": "node ./scripts/run-envio-with-env.mjs stop",
    "indexer:multichain:codegen": "node ./scripts/run-envio-with-env.mjs codegen --config config.multichain.mainnet.yaml",
    "indexer:multichain:dev": "node ./scripts/run-envio-with-env.mjs dev --config config.multichain.mainnet.yaml",
    "indexer:multichain:testnet:codegen": "node ./scripts/run-envio-with-env.mjs codegen --config config.multichain.testnet.yaml",
    "indexer:multichain:testnet:dev": "node ./scripts/run-envio-with-env.mjs dev --config config.multichain.testnet.yaml",
    "indexer:bridge-only:codegen": "node ./scripts/run-envio-with-env.mjs codegen --config config.multichain.bridge-only.yaml",
    "indexer:bridge-only:dev": "node ./scripts/run-envio-with-env.mjs dev --config config.multichain.bridge-only.yaml",
    "indexer:bridge-only:start": "node ./scripts/run-envio-with-env.mjs start --config config.multichain.bridge-only.yaml",
    "generate:ntt-addresses": "node ./scripts/generateNttAddresses.mjs",
    "test": "pnpm mocha",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "chai": "^4.5.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@mento-protocol/contracts": "0.6.0",
    "envio": "2.32.10",
    "viem": "2.47.0"
  },
  "optionalDependencies": {
    "generated": "link:generated"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
