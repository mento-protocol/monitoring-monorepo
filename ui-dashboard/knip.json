{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["scripts/*.{mjs,ts}", "vitest.mutation.config.ts"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{mjs,ts}", "*.config.*"],
  "ignoreDependencies": [
    "plotly.js-basic-dist-min",
    "tailwindcss",
    "axe-core",
    "@stryker-mutator/api"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
