{
  "ignore": {
    "rules": [
      "react-doctor/design-no-default-tailwind-palette",
      "react-doctor/design-no-em-dash-in-jsx-text",
      "react-doctor/design-no-redundant-size-axes",
      "react-doctor/design-no-bold-heading",
      "react-doctor/js-tosorted-immutable",
      "effect/no-event-handler",
      "react-you-might-not-need-an-effect/no-event-handler"
    ],
    "overrides": [
      {
        "files": [
          "**/*.test.{ts,tsx}",
          "**/*.spec.{ts,tsx}",
          "**/__tests__/**",
          "scripts/**"
        ],
        "rules": ["react-doctor/no-secrets-in-client-code"]
      },
      {
        "files": ["scripts/**"],
        "rules": ["knip/files"]
      },
      {
        "files": ["tests/browser/fixtures/**", "vitest.mutation.config.ts"],
        "rules": ["knip/files"]
      },
      {
        "files": ["src/lib/graphql.ts"],
        "rules": ["knip/exports"]
      }
    ]
  }
}
