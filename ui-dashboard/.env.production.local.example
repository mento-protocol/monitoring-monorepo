# Production env vars for Vercel — copy to .env.production.local and fill in values.
# .env.production.local is gitignored; this example file is committed.
#
# Only NEXT_PUBLIC_HASURA_URL_SEPOLIA_HOSTED is strictly required for the default
# "Celo Sepolia (hosted)" network. All other vars have sensible defaults.
#
# Local networks (devnet, celo-sepolia-local, celo-mainnet-local) are hidden by
# default on deployed environments. Set this to true in .env.local to show them.
# NEXT_PUBLIC_SHOW_LOCAL_NETWORKS=true

# ── Celo Sepolia (hosted Envio indexer) ──────────────────────────────────────

# GraphQL endpoint from your Envio hosted deployment dashboard.
NEXT_PUBLIC_HASURA_URL_SEPOLIA_HOSTED=https://indexer.dev.hyperindex.xyz/4530cdf/v1/graphql

# Admin secret for the hosted Hasura. Leave empty for Envio-hosted deployments
# (they use a bearer token on the GraphQL request, not an admin secret).
NEXT_PUBLIC_HASURA_SECRET_SEPOLIA_HOSTED=

# Block explorer base URL for address/tx links. Default is already correct.
# NEXT_PUBLIC_EXPLORER_URL_SEPOLIA_HOSTED=https://celo-sepolia.blockscout.com

# ── Celo Mainnet (hosted Envio indexer) — set when mainnet is live ────────────

NEXT_PUBLIC_HASURA_URL_MAINNET_HOSTED=https://indexer.hyperindex.xyz/60ff18c/v1/graphql
NEXT_PUBLIC_HASURA_SECRET_MAINNET_HOSTED=
