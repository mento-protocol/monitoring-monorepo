{
  "name": "@mento-protocol/ui-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-with-live-hasura.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "node ../scripts/eslint-baseline-diff.mjs check",
    "lint:baseline:update": "node ../scripts/eslint-baseline-diff.mjs update",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "node scripts/run-browser-tests.mjs",
    "test:browser:production": "node scripts/run-browser-tests.mjs --production",
    "test:browser:update-snapshots": "node scripts/run-browser-tests.mjs --update-snapshots",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "react-doctor": "react-doctor .",
    "react-doctor:diff": "bash ../scripts/check-react-doctor-diff.sh \"${REACT_DOCTOR_BASE_REF:-origin/main}\"",
    "react-doctor:score": "bash ../scripts/check-react-doctor-score.sh",
    "knip": "knip --config knip.json --no-progress",
    "knip:report": "knip --config knip.json --no-exit-code --no-progress",
    "size-limit": "size-limit"
  },
  "dependencies": {
    "@mento-protocol/monitoring-config": "workspace:*",
    "@sentry/nextjs": "^10.49.0",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@web3icons/react": "^4.1.17",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.30",
    "plotly.js-basic-dist-min": "^3.4.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "viem": "catalog:",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-plotly.js": "^2.6.4",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.11.4",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.10.1",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "knip": "6.12.2",
    "react-doctor": "0.1.6",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.0",
    "vitest-axe": "1.0.0-pre.5",
    "web-vitals": "^5.2.0"
  }
}
