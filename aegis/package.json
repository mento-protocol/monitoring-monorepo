{
  "name": "@mento-protocol/aegis",
  "version": "0.0.1",
  "private": true,
  "description": "A monitoring tool to expose the result of on-chain view calls as prometheus metrics that get ingested into grafana.",
  "license": "UNLICENSED",
  "author": "Mento Labs <eng@mentolabs.xyz>",
  "scripts": {
    "build": "nest build",
    "agent:deploy": "cd grafana-agent && gcloud builds submit --project mento-prod",
    "deploy": "./bin/deploy.sh",
    "dev": "nest start --watch",
    "format": "trunk fmt",
    "grafana": "open $(terraform -chdir=terraform state show module.grafana_dashboard.grafana_dashboard.aegis | grep 'url' | awk -F '\"' '{print $2}')",
    "knip": "knip --config knip.json --no-progress",
    "knip:report": "knip --config knip.json --no-exit-code --no-progress",
    "lint": "node ../scripts/eslint-baseline-diff.mjs check",
    "lint:baseline:update": "node ../scripts/eslint-baseline-diff.mjs update",
    "logs": "./bin/logs.sh",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest --watchman=false",
    "test:cov": "jest --coverage --watchman=false",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:watch": "jest --watch",
    "tf:apply": "terraform -chdir=terraform apply",
    "tf:deploy": "terraform -chdir=terraform apply",
    "tf:destroy": "terraform -chdir=terraform destroy",
    "tf:init": "terraform -chdir=terraform init",
    "tf:plan": "terraform -chdir=terraform plan",
    "trunk": "trunk",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "dependencies": {
    "@nestjs/common": "11.1.9",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.9",
    "@nestjs/schedule": "6.0.1",
    "@willsoto/nestjs-prometheus": "6.0.2",
    "abitype": "1.1.2",
    "cron": "4.3.4",
    "js-yaml": "4.1.1",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "viem": "2.39.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.12",
    "@nestjs/schematics": "11.0.9",
    "@trunkio/launcher": "1.3.4",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.47.0",
    "@typescript-eslint/parser": "8.47.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-unused-imports": "^4.2.0",
    "jest": "30.2.0",
    "knip": "6.12.2",
    "prettier": "3.6.2",
    "ts-jest": "29.4.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^22.0.0"
  },
  "volta": {
    "node": "22.14.0"
  }
}
