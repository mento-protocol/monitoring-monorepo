{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/main.ts", "src/**/*.spec.ts"],
  "project": ["src/**/*.ts", "*.config.*"],
  "ignoreBinaries": ["awk", "gcloud", "open", "terraform"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
