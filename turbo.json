{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "remoteCache": {
    "enabled": false
  },
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    ".npmrc",
    ".node-version",
    "eslint.config.mjs"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "tasks": {
    "lint": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "package.json",
        "eslint.config.*",
        "eslint-baseline.json",
        "$TURBO_ROOT$/scripts/eslint-baseline-diff.mjs"
      ],
      "outputs": []
    },
    "typecheck": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "package.json",
        "tsconfig*.json",
        "nest-cli.json",
        "$TURBO_ROOT$/tsconfig*.json"
      ],
      "outputs": []
    },
    "test": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "package.json",
        "vitest.config.*",
        "jest.config.*",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "knip": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "package.json", "knip.json"],
      "outputs": []
    }
  }
}
