{
  "name": "@mento-protocol/governance-watchdog",
  "version": "1.0.0",
  "private": true,
  "description": "Monitors Mento Governance events on-chain and sends notifications to Discord and Telegram",
  "author": "Mento Labs <eng@mentolabs.xyz>",
  "license": "ISC",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "cache:clear": "./bin/get-project-vars.sh --invalidate-cache",
    "deploy": "../scripts/deploy-gov-watchdog.sh",
    "deploy:function": "./bin/deploy-via-gcloud.sh",
    "deploy:terraform": "terraform -chdir=infra apply",
    "destroy": "terraform -chdir=infra destroy",
    "dev": "nodemon --ext ts --ignore dist --exec \"pnpm run start\"",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "gcp-build": "pnpm run build",
    "generate:env": "terraform -chdir=infra apply -target=local_file.env_file",
    "knip": "knip --config knip.json --no-progress",
    "knip:report": "knip --config knip.json --no-exit-code --no-progress",
    "lint": "eslint src/",
    "logs": "./bin/get-logs.sh",
    "reprocess:event": "tsx bin/reprocess-event.ts",
    "prestart": "pnpm run build",
    "start": "NODE_ENV=development functions-framework --target=governanceWatchdog",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:coverage": "vitest run --coverage",
    "test:integration": "pnpm run test:local:ProposalCreated && pnpm run test:local:ProposalQueued && pnpm run test:local:ProposalExecuted && pnpm run test:local:ProposalCanceled && pnpm run test:local:healthcheck",
    "test:local:ProposalCanceled": "curl -H \"Content-Type: application/json\" -d @src/events/fixtures/proposal-canceled.fixture.json localhost:8080",
    "test:local:ProposalCreated": "curl -H \"Content-Type: application/json\" -d @src/events/fixtures/proposal-created.fixture.json localhost:8080",
    "test:local:ProposalExecuted": "curl -H \"Content-Type: application/json\" -d @src/events/fixtures/proposal-executed.fixture.json localhost:8080",
    "test:local:ProposalQueued": "curl -H \"Content-Type: application/json\" -d @src/events/fixtures/proposal-queued.fixture.json localhost:8080",
    "test:local:healthcheck": "curl -H \"Content-Type: application/json\" -d @src/events/fixtures/health-check.fixture.json localhost:8080",
    "test:prod:ProposalCanceled": "./bin/test-deployed-function.sh ProposalCanceled",
    "test:prod:ProposalCreated": "./bin/test-deployed-function.sh ProposalCreated",
    "test:prod:ProposalExecuted": "./bin/test-deployed-function.sh ProposalExecuted",
    "test:prod:ProposalQueued": "./bin/test-deployed-function.sh ProposalQueued",
    "test:prod:healthcheck": "./bin/test-deployed-function.sh healthcheck",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "3.5.1",
    "@google-cloud/secret-manager": "5.6.0",
    "discord.js": "14.25.1",
    "env-schema": "6.0.1",
    "viem": "2.33.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.22.0",
    "knip": "^5.70.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.1.0"
  }
}
