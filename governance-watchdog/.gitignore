# Terraform (note: .terraform.lock.hcl IS committed, like the other monorepo stacks)
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/errored.tfstate
infra/*.tfvars
infra/*.auto.tfvars
infra/*.tfvars.json

# Cloud Function source archive (generated by data.archive_file)
function-source.zip
*.zip

# Generated by `terraform apply` (local-dotenv-file.tf) and bin/get-project-vars.sh
.env.yaml
.project_vars_cache
