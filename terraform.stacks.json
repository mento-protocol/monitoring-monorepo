{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": 1,
  "stacks": [
    {
      "id": "platform",
      "name": "Platform",
      "path": "terraform",
      "description": "Dashboard Vercel project, Upstash Redis, GCP project/APIs, Metrics Bridge Cloud Run shape, Aegis App Engine/Grafana Alloy bootstrap, CI Workload Identity Federation, project IAM, and repo-level GitHub Actions secrets.",
      "state": {
        "backend": "gcs",
        "bucket": "mento-terraform-tfstate-6ed6",
        "prefix": "monitoring-monorepo"
      },
      "providers": ["github", "google", "local", "upstash", "vercel"],
      "ci": {
        "validate": "changed-paths",
        "plan": "manual",
        "apply": "manual"
      },
      "applyPolicy": "human-review-required",
      "changedPathPatterns": [
        "terraform/**",
        "terraform.stacks.json",
        "scripts/tf-stacks.mjs",
        ".github/workflows/ci.yml",
        ".github/workflows/infra.yml"
      ],
      "aliases": ["pnpm infra:init", "pnpm infra:plan", "pnpm infra:apply"]
    },
    {
      "id": "alerts-rules",
      "name": "Alerts Rules",
      "path": "alerts/rules",
      "description": "Protocol Grafana alert rules plus the Aegis service-health rule group, Grafana folders, global notification policy, contact points, message templates, and mute timings.",
      "state": {
        "backend": "gcs",
        "bucket": "mento-terraform-tfstate-6ed6",
        "prefix": "alerts-rules"
      },
      "providers": ["grafana"],
      "ci": {
        "validate": "changed-paths",
        "plan": "pull-request",
        "apply": "push-main-production-environment"
      },
      "applyPolicy": "ci-production-environment-approved",
      "changedPathPatterns": [
        "alerts/rules/**",
        "terraform.stacks.json",
        "scripts/tf-stacks.mjs",
        ".github/workflows/ci.yml",
        ".github/workflows/infra.yml",
        ".github/workflows/alerts-rules.yml"
      ],
      "aliases": ["pnpm alerts:rules:init", "pnpm alerts:rules:plan"]
    },
    {
      "id": "alerts-delivery",
      "name": "Alerts Delivery",
      "path": "alerts/infra",
      "description": "Event-driven alert delivery: QuickNode webhooks, Cloud Functions, Sentry bridge, Slack channel lifecycle, Splunk On-Call rotation announcements, and related GCP resources.",
      "state": {
        "backend": "gcs",
        "bucket": "mento-terraform-tfstate-6ed6",
        "prefix": "alerts-infra"
      },
      "providers": [
        "archive",
        "github",
        "google",
        "http",
        "local",
        "null",
        "random",
        "restapi",
        "sentry"
      ],
      "ci": {
        "validate": "changed-paths",
        "plan": "pull-request",
        "apply": "push-main-production-environment"
      },
      "applyPolicy": "ci-production-environment-approved",
      "changedPathPatterns": [
        "alerts/infra/**",
        "terraform.stacks.json",
        "scripts/tf-stacks.mjs",
        ".github/workflows/ci.yml",
        ".github/workflows/infra.yml",
        ".github/workflows/alerts-infra.yml"
      ],
      "aliases": ["pnpm alerts:infra:init", "pnpm alerts:infra:plan"]
    },
    {
      "id": "aegis",
      "name": "Aegis",
      "path": "aegis/terraform",
      "description": "Aegis Grafana dashboard and Aegis folder. Alert rules (including the Aegis service-health rule group) and global routing live in alerts-rules.",
      "state": {
        "backend": "gcs",
        "bucket": "mento-terraform-tfstate-6ed6",
        "prefix": "aegis"
      },
      "providers": ["grafana"],
      "ci": {
        "validate": "changed-paths",
        "plan": "pull-request",
        "apply": "push-main-production-environment"
      },
      "applyPolicy": "ci-production-environment-approved",
      "changedPathPatterns": [
        "aegis/terraform/**",
        "terraform.stacks.json",
        "scripts/tf-stacks.mjs",
        ".github/workflows/ci.yml",
        ".github/workflows/infra.yml",
        ".github/workflows/aegis-terraform.yml"
      ],
      "aliases": ["pnpm aegis:tf:init", "pnpm aegis:tf:plan"]
    },
    {
      "id": "governance-watchdog",
      "name": "Governance Watchdog",
      "path": "governance-watchdog/infra",
      "description": "Mento Governance event watchdog: dedicated GCP project, Cloud Function (QuickNode webhook -> Discord/Telegram), QuickNode webhooks, Cloud Scheduler health check, Secret Manager, and Cloud Monitoring alert policies. Owns its own GCP project; not part of the alerts-delivery mento-alerts project.",
      "state": {
        "backend": "gcs",
        "bucket": "mento-terraform-tfstate-6ed6",
        "prefix": "governance-watchdog"
      },
      "providers": [
        "archive",
        "google",
        "google-beta",
        "local",
        "null",
        "random",
        "restapi",
        "time"
      ],
      "ci": {
        "validate": "changed-paths",
        "plan": "manual",
        "apply": "manual"
      },
      "applyPolicy": "human-review-required",
      "changedPathPatterns": [
        "governance-watchdog/**",
        "terraform.stacks.json",
        "scripts/tf-stacks.mjs",
        ".github/workflows/ci.yml",
        ".github/workflows/infra.yml"
      ],
      "aliases": ["pnpm gov-watchdog:tf:init", "pnpm gov-watchdog:tf:plan"]
    }
  ]
}
