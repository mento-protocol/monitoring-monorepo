{
  "name": "@mento-protocol/metrics-bridge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "node ../scripts/eslint-baseline-diff.mjs check",
    "lint:baseline:update": "node ../scripts/eslint-baseline-diff.mjs update",
    "knip": "knip --config knip.json --no-progress",
    "knip:report": "knip --config knip.json --no-exit-code --no-progress",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@mento-protocol/monitoring-config": "workspace:*",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "prom-client": "^15.1.3",
    "viem": "2.47.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "^22.19.13",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.2",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unused-imports": "^4.2.0",
    "fast-check": "^4.8.0",
    "globals": "^17.4.0",
    "knip": "6.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
