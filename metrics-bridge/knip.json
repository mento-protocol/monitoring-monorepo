{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["vitest.mutation.config.ts"],
  "project": ["src/**/*.ts", "*.config.*"],
  "ignoreDependencies": ["@stryker-mutator/api"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
